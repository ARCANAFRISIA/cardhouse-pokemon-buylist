generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PokemonCard {
  id              String   @id @default(cuid())

  cardKey         String   @unique
  cardmarketId    Int
  name            String
  setName         String?
  setCode         String?
  collectorNumber String?
  rarity          String?
  series          String?

  language        String   @default("English")
  condition       String   @default("NM")
  finishType      String   @default("Regular")

  imageUrl        String?
  active          Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prices          PokemonPrice[]

  @@index([cardmarketId])
  @@index([name])
  @@index([setCode])
  @@index([series])
  @@index([rarity])
  @@index([active])
}

model PokemonPrice {
  id                    String   @id @default(cuid())

  cardKey               String
  cardmarketId           Int
  source                 String   // POWERTOOLS, CM_PRICE_GUIDE, MANUAL
  marketPriceCents       Int?
  buyPriceCents          Int?

  cmTrendCents           Int?
  cmAvg7Cents            Int?
  cmAvg30Cents           Int?

  payoutPct              Int      @default(70)
  importedAt             DateTime @default(now())
  isCurrent              Boolean  @default(true)

  card                   PokemonCard @relation(fields: [cardKey], references: [cardKey], onDelete: Cascade)

  @@index([cardKey])
  @@index([cardmarketId])
  @@index([source])
  @@index([isCurrent])
  @@index([importedAt])
}

model Submission {
  id                String           @id @default(cuid())

  email             String?
  fullName          String?
  phone             String?

  addressLine1      String?
  postalCode        String?
  city              String?
  country           String?

  payoutMethod      String?
  iban              String?
  paypalEmail       String?

  status            String           @default("SUBMITTED")

  subtotalCents     Int              @default(0)
  serverTotalCents  Int              @default(0)
  clientTotalCents  Int?
  currency          String           @default("EUR")

  adminNote         String?
  customerMessage   String?
  metaText          String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  items             SubmissionItem[]

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model SubmissionItem {
  id               String     @id @default(cuid())

  submissionId     String
  cardKey          String?
  cardmarketId     Int

  cardName         String
  setName          String?
  setCode          String?
  collectorNumber  String?
  rarity           String?

  language         String     @default("English")
  condition        String     @default("NM")
  finishType       String     @default("Regular")

  qty              Int
  marketPriceCents Int?
  unitCents        Int
  lineCents        Int
  priceSource      String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  submission       Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([cardmarketId])
  @@index([cardKey])
}

model ImportBatch {
  id          String   @id @default(cuid())

  type        String   // POWERTOOLS_EXPORT, CM_PRICE_GUIDE
  filename    String?
  rowCount    Int      @default(0)
  success     Boolean  @default(false)
  message     String?

  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model BuylistSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}